# ──────────────────────────────────────────────────────────────────────────────
# Dados — não versionar arquivos de dados brutos e processados
# ──────────────────────────────────────────────────────────────────────────────
data/
spark-warehouse/

# ──────────────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────────────
logs/
*.log

# ──────────────────────────────────────────────────────────────────────────────
# Modelos treinados (arquivos grandes, gerados pelo pipeline)
# ──────────────────────────────────────────────────────────────────────────────
models/

# ──────────────────────────────────────────────────────────────────────────────
# Power BI — arquivos com dados e credenciais embutidas
# ──────────────────────────────────────────────────────────────────────────────
*.pbix
PowerBI/*.pbids

# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente e credenciais
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
*.key
secrets/

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ──────────────────────────────────────────────────────────────────────────────
# IDEs
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ──────────────────────────────────────────────────────────────────────────────
# Sistema operacional
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
